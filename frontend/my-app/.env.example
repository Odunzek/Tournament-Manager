# Firebase Configuration
# Get these values from your Firebase project settings
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Admin Authentication (Google Sign-In)
# Comma-separated list of Google email addresses authorized for admin access
# Example: admin1@gmail.com,admin2@gmail.com
NEXT_PUBLIC_ADMIN_EMAILS=your_admin_email@gmail.com

# App URL (for production deployment)
# This should be your production domain
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
